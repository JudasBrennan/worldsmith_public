{
  "name": "worldsmith-web",
  "version": "1.16.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check:syntax": "node scripts/check-syntax.mjs",
    "backup:live": "node scripts/backup-live.mjs",
    "assets:three": "node scripts/generate-three-render-assets.mjs",
    "assets:celestial": "node scripts/generate-celestial-preset-assets.mjs",
    "calibrate:activity": "node scripts/calibrate-stellar-activity.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:engine": "node --test --test-path-pattern=\"^(?!.*\\.ui\\.test\\.js$).*\\.test\\.js$\" tests/",
    "test:ui": "node --test \"tests/**/*.ui.test.js\"",
    "test": "node --test --test-reporter=./scripts/test-reporter.mjs \"tests/**/*.test.js\"",
    "test:report": "node --test --test-reporter=./scripts/test-reporter-md.mjs --test-reporter-destination=test-results.md \"tests/**/*.test.js\"",
    "check": "node scripts/check-syntax.mjs && eslint . && prettier --check . && node --test --test-reporter=./scripts/test-reporter.mjs \"tests/**/*.test.js\"",
    "build": "node scripts/build.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@napi-rs/canvas": "^0.1.95",
    "esbuild": "^0.27.3",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "jsdom": "^28.1.0",
    "pixelmatch": "^7.1.0",
    "prettier": "^3.5.2",
    "three": "^0.183.1"
  }
}
